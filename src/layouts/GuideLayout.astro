---
import Base from './Base.astro';

// Renders a single guide from its MDX frontmatter + body. All SEO lives here so
// every guide gets consistent canonical/OG tags, a visible breadcrumb, a
// "last verified" freshness signal, and BlogPosting + BreadcrumbList JSON-LD
// without any of it being hand-maintained per page.
interface Props {
  slug: string;
  frontmatter: {
    title: string;
    description: string;
    kicker: string;
    lede: string;
    datePublished: Date;
    dateModified: Date;
    patch?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage: string;
    featuredImage?: {
      src: string;
      alt: string;
      width: number;
      height: number;
    };
    schemaType: 'BlogPosting' | 'Article';
    tools: { label: string; href: string }[];
    bestFor?: string;
    sourceNote?: string;
    related: { label: string; href: string }[];
  };
}

const { slug, frontmatter: fm } = Astro.props;
const url = `https://notenoughcoins.net/guides/${slug}`;
const socialImage = fm.featuredImage
  ? new URL(fm.featuredImage.src, 'https://notenoughcoins.net').href
  : fm.ogImage;
const socialTitle = fm.ogTitle ?? fm.title;
const socialDescription = fm.ogDescription ?? fm.description;
const responsiveImageSrcset = fm.featuredImage
  ? [640, 960, 1280]
      .map((width) => `${fm.featuredImage!.src.replace(/\.webp$/, `-${width}.webp`)} ${width}w`)
      .concat(`${fm.featuredImage.src} ${fm.featuredImage.width}w`)
      .join(', ')
  : undefined;

const iso = (d: Date) => d.toISOString().slice(0, 10);
const human = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const headHtml = [
  `<title>${fm.title} | NotEnoughCoins</title>`,
  `<meta name="description" content="${fm.description}">`,
  `<link rel="canonical" href="${url}">`,
  `<meta property="og:url" content="${url}">`,
  `<meta property="og:type" content="article">`,
  `<meta property="og:site_name" content="NotEnoughCoins">`,
  `<meta property="og:title" content="${socialTitle}">`,
  `<meta property="og:description" content="${socialDescription}">`,
  `<meta property="og:image" content="${socialImage}">`,
  `<meta property="og:image:secure_url" content="${socialImage}">`,
  ...(fm.featuredImage
    ? [
        `<meta property="og:image:type" content="image/webp">`,
        `<meta property="og:image:width" content="${fm.featuredImage.width}">`,
        `<meta property="og:image:height" content="${fm.featuredImage.height}">`,
        `<meta property="og:image:alt" content="${fm.featuredImage.alt}">`,
      ]
    : []),
  `<meta name="twitter:card" content="summary_large_image">`,
  `<meta name="twitter:title" content="${socialTitle}">`,
  `<meta name="twitter:description" content="${socialDescription}">`,
  `<meta name="twitter:image" content="${socialImage}">`,
  ...(fm.featuredImage
    ? [`<meta name="twitter:image:alt" content="${fm.featuredImage.alt}">`]
    : []),
  `<script type="application/ld+json">${JSON.stringify({
    '@context': 'https://schema.org',
    '@type': fm.schemaType,
    headline: fm.title,
    description: fm.description,
    datePublished: iso(fm.datePublished),
    dateModified: iso(fm.dateModified),
    author: { '@type': 'Organization', name: 'NotEnoughCoins' },
    publisher: { '@type': 'Organization', name: 'Coflnet GmbH' },
    image: socialImage,
    mainEntityOfPage: url,
    url,
  })}</script>`,
  `<script type="application/ld+json">${JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://notenoughcoins.net/' },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://notenoughcoins.net/guides' },
      { '@type': 'ListItem', position: 3, name: fm.title, item: url },
    ],
  })}</script>`,
].join('\n    ');
---

<Base headHtml={headHtml}>
  <main>
    <div class="site-shell article-layout">
      <article class="article">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/guides">Guides</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{fm.kicker}</span>
        </nav>
        <p class="article-kicker">{fm.kicker}</p>
        <h1>{fm.title}</h1>
        <p class="article-freshness">
          Last verified <time datetime={iso(fm.dateModified)}>{human(fm.dateModified)}</time>{
            fm.patch ? ` · Patch ${fm.patch}` : ''
          }
        </p>
        <p class="lede">{fm.lede}</p>

        {fm.featuredImage && (
          <figure class="article-feature-image">
            <img
              src={fm.featuredImage.src}
              srcset={responsiveImageSrcset}
              sizes="(max-width: 720px) calc(100vw - 5.5rem), (max-width: 900px) calc(100vw - 7rem), 750px"
              alt={fm.featuredImage.alt}
              width={fm.featuredImage.width}
              height={fm.featuredImage.height}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        )}

        <slot />

        {fm.related.length > 0 && (
          <>
            <h2>Read next</h2>
            <ul class="related-list">
              {fm.related.map((r) => (
                <li><a href={r.href}>{r.label}</a></li>
              ))}
            </ul>
          </>
        )}
      </article>

      <aside class="article-aside">
        {fm.tools.length > 0 && (
          <div>
            <h3>Best paired tools</h3>
            <ul class="tool-list">
              {fm.tools.map((t) => (
                <li><a href={t.href}>{t.label}</a></li>
              ))}
            </ul>
          </div>
        )}
        {fm.bestFor && (
          <div>
            <h3>Best for</h3>
            <p>{fm.bestFor}</p>
          </div>
        )}
        {fm.sourceNote && (
          <div>
            <h3>Sources</h3>
            <p>{fm.sourceNote}</p>
          </div>
        )}
      </aside>
    </div>
  </main>
</Base>
