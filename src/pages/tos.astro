---
import Base from '../layouts/Base.astro';
const headHtml = "<title>Historic NotEnoughCoins Terms of Service</title>\n        <meta name=\"description\" content=\"Historic terms that applied to NotEnoughCoins before the service was terminated. Current site operation follows Coflnet's live terms.\">\n        <link rel=\"canonical\" href=\"https://notenoughcoins.net/tos\">";
const bodyHtml = "<main>\n            <div class=\"site-shell\">\n                <section class=\"policy-shell\">\n                    <span class=\"badge warning\">Historical document</span>\n                    <h1>Historic NotEnoughCoins Terms of Service</h1>\n                    <p class=\"lede\">These terms governed the old NotEnoughCoins paid mod before it was discontinued. The current NotEnoughCoins site operates under the live <a href=\"https://coflnet.com/terms-of-service\">Coflnet Terms of Service</a>.</p>\n                    <p>The old text is preserved here only for historical context. It is not a promise that the discontinued mod remains available, supported or redeemable today.</p>\n\n                    <h2>Definitions used in the historic terms</h2>\n                    <ul class=\"policy-list\">\n                        <li><strong>NotEnoughCoins</strong> referred to the digital software provided through this website for Hypixel SkyBlock.</li>\n                        <li><strong>Service</strong> referred to access to and use of NotEnoughCoins.</li>\n                        <li><strong>You</strong> referred to the individual or entity accessing the software or service.</li>\n                    </ul>\n\n                    <h2>Historic rules</h2>\n                    <ol class=\"policy-list\">\n                        <li><strong>Abusive conduct prohibited.</strong> Access could be terminated if a user engaged in abusive behavior toward community members.</li>\n                        <li><strong>Distribution prohibited.</strong> Access could be terminated for distributing or attempting to distribute copies of the mod without explicit written consent.</li>\n                        <li><strong>No troll tickets or deliberate misinformation.</strong> Access could be terminated for intentionally wasting staff time or knowingly spreading incorrect information about the mod.</li>\n                        <li><strong>No liability for in-game purchases.</strong> The project disclaimed liability for in-game purchases or losses made while using the mod.</li>\n                        <li><strong>Use at your own risk.</strong> Users accepted the risk of using the mod, including the possibility of Hypixel sanctions or the absence of refunds.</li>\n                        <li><strong>Service termination could occur at any time.</strong> The historic terms expressly stated that NEC packages were not guaranteed to remain functional indefinitely and could end without notice.</li>\n                    </ol>\n\n                    <h2>Historic note</h2>\n                    <p>That final rule is the part that matters most today: the paid mod did terminate, the migration offer expired in January 2026, and the NotEnoughCoins site is now a SkyBlock guide and tool hub rather than a storefront.</p>\n                    <p>The NotEnoughCoins mod was not affiliated with Mojang AB or the Hypixel Network.</p>\n                </section>\n            </div>\n        </main>";
---

<Base headHtml={headHtml} bodyHtml={bodyHtml} />
