---
import Base from '../layouts/Base.astro';
const headHtml = "<title>NEC Premium | Historic NotEnoughCoins Route</title>\n        <meta name=\"description\" content=\"Legacy NEC Premium page kept live for backlinks. NEC Premium is discontinued; use the maintained SkyCofl mod page and current Hypixel SkyBlock guides instead.\">\n        <link rel=\"canonical\" href=\"https://notenoughcoins.net/nec-premium\">\n\n        <meta property=\"og:url\" content=\"https://notenoughcoins.net/nec-premium\">\n        <meta property=\"og:type\" content=\"website\">\n        <meta property=\"og:title\" content=\"NEC Premium\">\n        <meta property=\"og:description\" content=\"NEC Premium is no longer sold or activated. Use the maintained SkyCofl mod page and live SkyBlock guides instead.\">\n        <meta property=\"og:image\" content=\"https://notenoughcoins.net/static/NEC.png\">";
const bodyHtml = "<main>\n            <div class=\"site-shell\">\n                <section class=\"hero\">\n                    <span class=\"badge warning\">Historic route</span>\n                    <h1>NEC Premium is no longer a live product</h1>\n                    <p class=\"lede\">This page exists because older backlinks still point to NEC Premium. The old paid NotEnoughCoins service is discontinued, there is no active NEC Premium entitlement flow, and the right maintained Coflnet mod path is now the <a href=\"https://sky.coflnet.com/mod\">SkyCofl mod page</a>.</p>\n                    <div class=\"button-row\">\n                        <a class=\"button\" href=\"https://sky.coflnet.com/mod\">Open SkyCofl mod page</a>\n                        <a class=\"button secondary\" href=\"/faq\">See current answers</a>\n                        <a class=\"button secondary\" href=\"/guides\">Browse guides</a>\n                    </div>\n                </section>\n\n                <section class=\"section\">\n                    <div class=\"section-header\">\n                        <span class=\"badge success\">Useful replacements</span>\n                        <h2>What to use instead</h2>\n                        <p>Most legacy NEC Premium searches are really looking for one of three things now: a current mod path, a current tool comparison, or practical flipping guidance.</p>\n                    </div>\n                    <div class=\"card-grid\">\n                        <article class=\"card\">\n                            <h3>Current mod path</h3>\n                            <p>If you are trying to install or update the maintained Coflnet tooling, go straight to the <a href=\"https://sky.coflnet.com/mod\">SkyCofl mod page</a>.</p>\n                        </article>\n                        <article class=\"card\">\n                            <h3>Current premium-style workflow overview</h3>\n                            <p>The <a href=\"/guides/flipping-tools-comparison-2026\">flipping tools comparison guide</a> explains how the current SkyCofl, BazaarPro, Skyblock.bz and BazaarTracker surfaces fit together.</p>\n                        </article>\n                        <article class=\"card\">\n                            <h3>Guides worth opening next</h3>\n                            <p>For live market use rather than legacy access, start with the <a href=\"/guides/market-literacy-margin-volume-risk\">market-literacy guide</a> and the <a href=\"/guides/passive-bazaar-orders-guide\">passive bazaar orders guide</a>.</p>\n                        </article>\n                    </div>\n                </section>\n            </div>\n        </main>";
---

<Base headHtml={headHtml} bodyHtml={bodyHtml} />
