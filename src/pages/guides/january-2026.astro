import Base from '../../layouts/Base.astro';
const headHtml = "<title>January 2026 Hypixel SkyBlock Guides | NotEnoughCoins</title>\n    <meta name=\"description\" content=\"The January 2026 NotEnoughCoins guide archive covering auction house flipping, bazaar flipping, craft flipping and the core slayer overview for Hypixel SkyBlock. See also the December 2025 greenhouse guide.\">\n    <link rel=\"canonical\" href=\"https://notenoughcoins.net/guides/january-2026\">\n\n    <meta property=\"og:url\" content=\"https://notenoughcoins.net/guides/january-2026\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"January 2026 Hypixel SkyBlock Guides\">\n    <meta property=\"og:description\" content=\"Browse the January 2026 NotEnoughCoins guide releases for core flipping and slayer fundamentals.\">\n    <meta property=\"og:image\" content=\"https://notenoughcoins.net/static/NEC.png\">";
const bodyHtml = "<main>\n      <div class=\"site-shell\">\n        <section class=\"hero\">\n          <span class=\"badge\">Month archive</span>\n          <h1>January 2026 guides</h1>\n          <p class=\"lede\">January set the foundation for the whole library: auction house flipping, bazaar flipping, craft structure and the slayer overview. If you want the core language the later niche pages build on, start with this month.</p>\n          <div class=\"button-row\">\n            <a class=\"button\" href=\"/guides\">Back to all guides</a>\n            <a class=\"button secondary\" href=\"/guides/december-2025\">Previous month: December 2025</a>\n            <a class=\"button secondary\" href=\"/guides/february-2026\">Next month: February 2026</a>\n          </div>\n        </section>\n\n        <section class=\"section\">\n          <div class=\"section-header\">\n            <span class=\"badge success\">Released in January</span>\n            <h2>Foundational flipping and slayer pages</h2>\n            <p>These four releases established the core flipping workflows and the first combat money-making branch before the library expanded into mining, farming and update coverage.</p>\n          </div>\n          <div class=\"archive-grid\">\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-01-05 • AH Flipping</span>\n              <h3><a href=\"/guides/ah-flipping-guide-2026\">Auction House Flipping Guide for Hypixel SkyBlock in 2026</a></h3>\n              <p>Manual filters, post-tax margins and the difference between browse-everything flipping and targeted late-game item work.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-01-12 • Bazaar Flipping</span>\n              <h3><a href=\"/guides/bazaar-flipping-guide-2026\">Bazaar Flipping Guide for Hypixel SkyBlock in 2026</a></h3>\n              <p>Buy orders, sell offers, liquidity checks and why volume matters more than pretty percentage margins.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-01-19 • Craft Flipping</span>\n              <h3><a href=\"/guides/craft-flipping-guide-2026\">Craft Flipping Guide for Hypixel SkyBlock in 2026</a></h3>\n              <p>Why finished goods keep selling above ingredient cost and where creators find the laziness tax.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-01-26 • Slayers</span>\n              <h3><a href=\"/guides/slayer-money-making-guide-2026\">Best Slayer Money-Making Methods in Hypixel SkyBlock</a></h3>\n              <p>A slayer-wide overview that frames consistency, gear walls and why not every boss deserves your time.</p>\n            </article>\n          </div>\n        </section>\n      </div>\n    </main>";
---

