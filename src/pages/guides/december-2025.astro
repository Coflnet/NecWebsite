---
import Base from '../../layouts/Base.astro';
const headHtml = "<title>December 2025 Hypixel SkyBlock Guides | NotEnoughCoins</title>\n    <meta name=\"description\" content=\"The December 2025 NotEnoughCoins guide archive covering the greenhouse update for Hypixel SkyBlock, including unlock requirements, mutation logic and farming QoL.\">\n    <link rel=\"canonical\" href=\"https://notenoughcoins.net/guides/december-2025\">\n\n    <meta property=\"og:url\" content=\"https://notenoughcoins.net/guides/december-2025\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"December 2025 Hypixel SkyBlock Guides\">\n    <meta property=\"og:description\" content=\"Browse the December 2025 NotEnoughCoins guide release for the greenhouse update in Hypixel SkyBlock.\">\n    <meta property=\"og:image\" content=\"https://notenoughcoins.net/static/NEC.png\">";
const bodyHtml = "<main>\n      <div class=\"site-shell\">\n        <section class=\"hero\">\n          <span class=\"badge\">Month archive</span>\n          <h1>December 2025 guides</h1>\n          <p class=\"lede\">December brought the greenhouse system as a preview of the farming rework to come. This page covers the unlock path, mutation mechanics and how the early greenhouse economy started forming before the broader 2026 farming patches landed.</p>\n          <div class=\"button-row\">\n            <a class=\"button\" href=\"/guides\">Back to all guides</a>\n            <a class=\"button secondary\" href=\"/guides/january-2026\">Next month: January 2026</a>\n          </div>\n        </section>\n\n        <section class=\"section\">\n          <div class=\"section-header\">\n            <span class=\"badge success\">Released in December</span>\n            <h2>Farming system preview</h2>\n            <p>The greenhouse update turned farming into a planning game: unlock it cleanly, learn mutation shapes and price crops with live tools before you scale.</p>\n          </div>\n          <div class=\"archive-grid\">\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2025-12-15 • Farming Update</span>\n              <h3><a href=\"/guides/greenhouse-update-guide-2026\">Greenhouse Update Guide for Hypixel SkyBlock</a></h3>\n              <p>Unlock requirements, mutation logic, farming QoL and the right way to price greenhouse outputs before you fill the plot.</p>\n            </article>\n          </div>\n        </section>\n      </div>\n    </main>";
---

<Base headHtml={headHtml} bodyHtml={bodyHtml} />
