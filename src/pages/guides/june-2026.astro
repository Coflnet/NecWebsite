import Base from '../../layouts/Base.astro';
const headHtml = "<title>June 2026 Hypixel SkyBlock Guides | NotEnoughCoins</title>\n    <meta name=\"description\" content=\"The June 2026 NotEnoughCoins guide archive covering Lotus Atoll 0.25, Guardian Slayer, the new fishing island, the June trend report and a post-patch economy recap in Hypixel SkyBlock.\">\n    <link rel=\"canonical\" href=\"https://notenoughcoins.net/guides/june-2026\">\n\n    <meta property=\"og:url\" content=\"https://notenoughcoins.net/guides/june-2026\">\n    <meta property=\"og:type\" content=\"website\">\n    <meta property=\"og:title\" content=\"June 2026 Hypixel SkyBlock Guides\">\n    <meta property=\"og:description\" content=\"Browse the June 2026 NotEnoughCoins guide releases for the 0.25 Lotus Atoll launch, update-watch pages and the latest SkyBlock trend radar.\">\n    <meta property=\"og:image\" content=\"https://notenoughcoins.net/static/NEC.png\">";
const bodyHtml = "<main>\n      <div class=\"site-shell\">\n        <section class=\"hero\">\n          <span class=\"badge\">Month archive</span>\n          <h1>June 2026 guides</h1>\n          <p class=\"lede\">June opened with the 0.25 Lotus Atoll launch, then followed with Guardian Slayer prep, the June trend radar, the new fishing island deep-dive and a post-patch economy recap. This month is the bridge between the spring update cycle and the summer meta.</p>\n          <div class=\"button-row\">\n            <a class=\"button\" href=\"/guides\">Back to all guides</a>\n            <a class=\"button secondary\" href=\"/guides/may-2026\">Previous month: May 2026</a>\n          </div>\n        </section>\n\n        <section class=\"section\">\n          <div class=\"section-header\">\n            <span class=\"badge success\">Released in June</span>\n            <h2>Update watch and patch coverage</h2>\n            <p>These five pages track the 0.25 Lotus Atoll launch, Guardian Slayer prep, the monthly trend radar, the fishing island deep-dive and a post-patch economy recap so readers stay ahead of the shifting meta.</p>\n          </div>\n          <div class=\"archive-grid\">\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-06-01 • Patch Notes</span>\n              <h3><a href=\"/guides/hypixel-skyblock-0-25-lotus-atoll-update\">Hypixel SkyBlock 0.25 Lotus Atoll Update Guide</a></h3>\n              <p>A practical synthesis of official notes, YouTube transcript recaps and Reddit feedback for fast, low-regret patch-week decisions.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-06-08 • Update Watch</span>\n              <h3><a href=\"/guides/guardian-slayer-guide-2026\">Guardian Slayer Update Guide for Hypixel SkyBlock</a></h3>\n              <p>What is actually confirmed about the fishing-based slayer loop, how to prepare safely and why broad fishing readiness beats rumor-driven investing.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-06-15 • Trend Report</span>\n              <h3><a href=\"/guides/hypixel-skyblock-trends-june-2026\">Latest Hypixel SkyBlock Trends (June 2026)</a></h3>\n              <p>A data-backed trend radar with visual charts for current player focus, market behavior and patch cadence.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-06-22 • Fishing Update</span>\n              <h3><a href=\"/guides/new-fishing-island-guide-2026\">New Fishing Island Guide for Hypixel SkyBlock</a></h3>\n              <p>The rebuilt fishing outpost, personal boat, bites, merchant changes and why the first island is really part of a larger fishing system.</p>\n            </article>\n            <article class=\"article-card\">\n              <span class=\"article-meta\">2026-06-29 • Economy</span>\n              <h3><a href=\"/guides/post-lotus-atoll-economy-recap\">Post-Lotus Atoll Economy Recap: What Settled and What Didn't</a></h3>\n              <p>Four weeks after 0.25, a clear-eyed look at which markets stabilized, which hype spikes faded and where the smart coins are moving next.</p>\n            </article>\n          </div>\n        </section>\n      </div>\n    </main>";
